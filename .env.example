# Database
DATABASE_URL=postgresql://lifeos:lifeos@localhost:5432/lifeos

# Redis
REDIS_URL=redis://localhost:6379

# API
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth (add secrets when auth is implemented)
# SECRET_KEY=

# AI Providers
# Get your Groq key at: https://console.groq.com/keys
GROQ_API_KEY=
# Optional fallback
# GEMINI_API_KEY=

# Voice Providers (optional — browser TTS works without any key)
# ElevenLabs: https://elevenlabs.io
# ELEVENLABS_API_KEY=
# OpenAI TTS: https://platform.openai.com
# OPENAI_API_KEY=

# Desktop (set to true when building for Tauri)
# NEXT_PUBLIC_DESKTOP=false
